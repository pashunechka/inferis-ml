{
  "name": "inferis-react",
  "version": "1.0.0",
  "description": "React hooks and providers for inferis-ml",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "inferis-ml": ">=1.0.0"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "inferis-ml": "file:../../",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "@types/react": "^19.1.2"
  },
  "license": "MIT",
  "homepage": "https://github.com/pashunechka/inferis-ml/tree/main/packages/inferis-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pashunechka/inferis-ml.git",
    "directory": "packages/inferis-react"
  },
  "keywords": [
    "inferis",
    "react",
    "hooks",
    "ml",
    "ai",
    "webgpu",
    "wasm"
  ]
}
